{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/app/**",
              "components/core/**",
              "components/tarot/**",
              "prototypes/nightly-checkin/**",
              "ui_kits/hint-app/**",
              "ui_kits/hint-app/screens/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Fraunces|Hanken Grotesk))/i]",
        "message": "Font not provided by the design system. Available: Fraunces, Hanken Grotesk."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|gold|aqua|rose|soon)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'gold' | 'aqua' | 'rose' | 'soon'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|fullWidth|iconLeft|iconRight|disabled|href|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, fullWidth, iconLeft, iconRight, disabled, href, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|gold|secondary|ghost|outline)$/]",
        "message": "<Button> variant must be one of 'primary' | 'gold' | 'secondary' | 'ghost' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatBubble'] > JSXAttribute > JSXIdentifier[name!=/^(?:role|children|key|ref|className|style|children)$/]",
        "message": "<ChatBubble> doesn't accept that prop. Declared props: role, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatBubble'] > JSXAttribute[name.name='role'] > Literal[value!=/^(?:user|hint)$/]",
        "message": "<ChatBubble> role must be one of 'user' | 'hint'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|tracking|children|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: tone, tracking, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:gold|muted|aqua)$/]",
        "message": "<Eyebrow> tone must be one of 'gold' | 'muted' | 'aqua'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='tracking'] > Literal[value!=/^(?:normal|wide)$/]",
        "message": "<Eyebrow> tracking must be one of 'normal' | 'wide'."
      },
      {
        "selector": "JSXOpeningElement[name.name='GlassCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:elevation|glow|radius|padding|children|key|ref|className|style|children)$/]",
        "message": "<GlassCard> doesn't accept that prop. Declared props: elevation, glow, radius, padding, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='GlassCard'] > JSXAttribute[name.name='elevation'] > Literal[value!=/^(?:soft|card|hero)$/]",
        "message": "<GlassCard> elevation must be one of 'soft' | 'card' | 'hero'."
      },
      {
        "selector": "JSXOpeningElement[name.name='GlassCard'] > JSXAttribute[name.name='radius'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<GlassCard> radius must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LuckyTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:image|value|label|swatch|key|ref|className|style|children)$/]",
        "message": "<LuckyTile> doesn't accept that prop. Declared props: image, value, label, swatch."
      },
      {
        "selector": "JSXOpeningElement[name.name='ModuleTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|hint|icon|locked|key|ref|className|style|children)$/]",
        "message": "<ModuleTile> doesn't accept that prop. Declared props: title, hint, icon, locked."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScoreMeter'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|score|area|layout|key|ref|className|style|children)$/]",
        "message": "<ScoreMeter> doesn't accept that prop. Declared props: label, score, area, layout."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScoreMeter'] > JSXAttribute[name.name='area'] > Literal[value!=/^(?:love|wealth|career|study|people|overall)$/]",
        "message": "<ScoreMeter> area must be one of 'love' | 'wealth' | 'career' | 'study' | 'people' | 'overall'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScoreMeter'] > JSXAttribute[name.name='layout'] > Literal[value!=/^(?:row|stack)$/]",
        "message": "<ScoreMeter> layout must be one of 'row' | 'stack'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TarotCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|whisper|image|back|width|flipped|onFlip|key|ref|className|style|children)$/]",
        "message": "<TarotCard> doesn't accept that prop. Declared props: name, whisper, image, back, width, flipped, onFlip."
      },
      {
        "selector": "JSXOpeningElement[name.name='TarotCard'] > JSXAttribute[name.name='back'] > Literal[value!=/^(?:nocturne|deck)$/]",
        "message": "<TarotCard> back must be one of 'nocturne' | 'deck'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ThemeToggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:theme|onChange|sunIcon|moonIcon|key|ref|className|style|children)$/]",
        "message": "<ThemeToggle> doesn't accept that prop. Declared props: theme, onChange, sunIcon, moonIcon."
      },
      {
        "selector": "JSXOpeningElement[name.name='ThemeToggle'] > JSXAttribute[name.name='theme'] > Literal[value!=/^(?:nocturne|daybreak)$/]",
        "message": "<ThemeToggle> theme must be one of 'nocturne' | 'daybreak'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
