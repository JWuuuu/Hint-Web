OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral

DATABASE_URL=postgresql://user:password@host:5432/database

# Local development only. Production hosts usually provide PORT automatically.
API_PORT=5050
PORT=5173
BASE_PATH=/
API_PROXY_TARGET=http://localhost:5050

# Set this only when the deployed frontend and API are on different origins.
# Leave blank when /api is reverse-proxied to the API on the same domain.
VITE_API_BASE_URL=

LOG_LEVEL=info
