{
  "name": "hint-workspace",
  "version": "0.0.0",
  "packageManager": "pnpm@11.5.0",
  "license": "MIT",
  "scripts": {
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "build:api": "pnpm --filter @workspace/api-server run build",
    "build:web": "pnpm --filter @workspace/hint run build",
    "db:push": "pnpm --filter @workspace/db run push",
    "start:api": "pnpm --filter @workspace/api-server run start",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  }
}
